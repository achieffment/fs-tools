#!/usr/bin/env bash
# Кликабельная обёртка для macOS (Finder): откат прогона нормализатора к
# состоянию из git — восстанавливает отслеживаемые файлы и удаляет
# неотслеживаемые объекты. Выполняется без запроса.
#
# Безопасность (см. также раздел в README):
#  - работает ТОЛЬКО внутри каталога самого скрипта (.), никогда не трогает
#    файлы вне него.
#
# Логика в функции main (вызов последней строкой): интерпретатор читает скрипт
# целиком до выполнения и корректно отрабатывает, даже если файл будет переписан.
set -euo pipefail

main() {
    local here
    here="$(cd -- "$(dirname -- "$0")" && pwd)"
    cd "$here"

    pause_exit() {
        echo
        read -n 1 -s -r -p "Нажмите любую клавишу для выхода..." || true
        echo
        exit "$1"
    }

    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "Это не git-репозиторий — откат через git недоступен." >&2
        pause_exit 1
    fi

    # Откат с core.ignorecase=false и в порядке reset -> clean -> checkout. На
    # регистронезависимой ФС (macOS, Windows) переименования, отличающиеся ТОЛЬКО
    # регистром (CaseRule: archive -> Archive и т.п.), git обычными командами не
    # возвращает: путь считается тем же, имя не переименовывается. С ignorecase=false
    # мис-кейсовый объект становится неотслеживаемым, удаляется на шаге 2 и
    # пересоздаётся на шаге 3 уже с правильным регистром.

    # 1. Снимаем индекс к HEAD (если переименования были staged) — мис-кейс станет untracked.
    git -c core.ignorecase=false reset -q -- .

    # 2. Удаляем неотслеживаемые объекты (мис-кейс, опустевшие нормализованные каталоги
    #    и пр.). Флаг -x обязателен: при case-only переименовании каталога с
    #    игнорируемым файлом (демо hidden/.env — негейт в .gitignore привязан к
    #    строчному hidden/.env и после hidden -> Hidden перестаёт срабатывать) обычный
    #    `clean -fd` этот .env не удаляет, мис-кейсовый каталог остаётся непустым, и на
    #    регистронезависимой ФС git не может его удалить ("Unlink of file 'hidden' failed").
    git -c core.ignorecase=false clean -fdx -- .

    # 2a. Журнал .fs-log (в .gitignore) уже удалён шагом 2 (флаг -x). Дублируем явным
    #     удалением как страховку (только в этом каталоге).
    rm -f .fs-log

    # 3. Возвращаем отслеживаемые файлы к версии из git (только в этом каталоге).
    git -c core.ignorecase=false checkout -- .

    echo "Готово: examples/normalizer/ возвращён к состоянию из git." >&2
    pause_exit 0
}

main "$@"
