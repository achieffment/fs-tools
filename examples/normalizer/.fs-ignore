# Демонстрация фильтра .fs-ignore (gitignore-семантика поверх pathspec).
# Якоря отсчитываются от корня нормализации (самого examples/normalizer/), порядок строк
# значим, ! - override. Все паттерны привязаны к 10-ignore, поэтому остальные
# примеры (01-09, 11-mix) не затрагиваются. Сам .fs-ignore скрыт (имя на .) и
# при обходе пропускается, поэтому не нормализуется и не матчится.
#
# В gitignore комментарий - только ведущий #; инлайн-комментарий после паттерна
# стал бы частью паттерна, поэтому пояснения держим на отдельных строках.

# Якорь с ведущим / - конкретный каталог от корня нормализации.
/10-ignore/anchored/archive

# Без ведущего /, но со срединным / - якорится так же (от корня).
10-ignore/relative/archive

# Исключить каталог целиком (рекурсивно)...
/10-ignore/reincluded
# ...но вернуть подкаталог proc (override; порядок строк значим).
!/10-ignore/reincluded/proc

# Basename без / - совпадает с объектом cache на любой глубине под 10-ignore.
cache

# Файлы по расширению (*.bak в одном каталоге)...
/10-ignore/file-glob/*.bak
# ...но один .bak-файл возвращаем (override; * не пересекает /).
!/10-ignore/file-glob/Сохранить.bak

# Один конкретный файл по полному пути; расширение значимо, поэтому
# одноимённый файл без .txt (Пароли) под паттерн не попадает и нормализуется.
/10-ignore/file-exact/Пароли.txt

# Постоянное игнорирование файла по имени (basename, на любой глубине - как cache)...
Конспект.txt
# ...но разблокировать один экземпляр (override по якорю; порядок строк значим).
!/10-ignore/file-basename/keep/Конспект.txt

# Каталог с # в имени: срединный # литерален (комментарий - только ведущий #).
/10-ignore/hash/C# заметки

# Каталог с ++ в имени: + - обычный символ, а не метасимвол.
/10-ignore/plus/C++ проекты

# Проекты занятий исключены целиком (* - имя занятия в пределах сегмента)...
/10-ignore/nested-reinclude/Activities/*/Projects
# ...но папки Data внутри них возвращаем на любой глубине (** сквозь сегменты,
# в т.ч. под исключённым Archive; порядок строк значим, ! - override).
!/10-ignore/nested-reinclude/Activities/*/Projects/**/Data
