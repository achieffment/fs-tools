# Конфигурация веб-хуков уведомлений: FSCHK_* — режим проверки (fs-checker),
# FSSYN_* — режим синхронизации (fs-syncher), FSSCH_* — режим проверки схемы
# (fs-schemer).
# Скопируйте в .env в корне проекта (.env в репозиторий не попадает).
# Путь к .env: FS_TOOLS_HOME/.env (его экспортируют обёртки bin/*), при отсутствии
# переменной — .env в текущем рабочем каталоге.
#
# Приоритет: переменные окружения процесса важнее значений из .env.
# Без *_WEBHOOK_URL уведомления соответствующего режима отключены; токен необязателен.
# URL обязан быть https:// (токен не уходит по нешифрованному каналу).

# Проверка структуры (fs-checker): уведомление об отсутствующих путях.
FSCHK_WEBHOOK_URL=https://example.com/hook
FSCHK_WEBHOOK_TOK=секретный-токен

# Синхронизация (fs-syncher): уведомление об ошибке прогона/блокировке delete-guard.
FSSYN_WEBHOOK_URL=https://example.com/hook
FSSYN_WEBHOOK_TOK=секретный-токен

# Проверка схемы (fs-schemer): уведомление о нарушениях структуры/контента.
FSSCH_WEBHOOK_URL=https://example.com/hook
FSSCH_WEBHOOK_TOK=секретный-токен
